#!/bin/bash
set -e

case "$1" in
    remove)
        # Remove the diversion on package removal
        if dpkg-divert --list ns-agent | grep -q snmpd.conf; then
            dpkg-divert --package ns-agent --remove --rename \
                /etc/snmp/snmpd.conf
        fi
        
        # Restart snmpd with original config
        systemctl restart snmpd 2>/dev/null || true
        ;;
    
    purge)
        # On purge, clean everything
        if dpkg-divert --list ns-agent | grep -q snmpd.conf; then
            dpkg-divert --package ns-agent --remove --rename \
                /etc/snmp/snmpd.conf
        fi
        rm -f /etc/snmp/snmpd.conf.ns-agent
        systemctl restart snmpd 2>/dev/null || true
        ;;
    
    upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
        # Nothing to do
        ;;
esac

#DEBHELPER#

exit 0
